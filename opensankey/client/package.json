    "bootstrap": "^5.1.1",
    "colormap": "^2.3.2",
    "cpr": "^3.0.1",
    "cross-conf-env": "^1.2.1",
    "cross-env": "^7.0.3",
    "d3": "^6.7.0",
    "d3-textwrap": "^3.0.0",
    "deep-diff": "^1.0.2",
    "extract-zip": "^2.0.1",
    "file-saver": "^2.0.5",
    "html-react-parser": "^1.2.7",
    "lz-string": "^1.4.4",
    "npm-build-zip": "^1.0.3",
    "react": "^17.0.2",
