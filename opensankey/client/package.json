    "jest": "^29.7.0",
    "jest-html": "^1.5.0",
    "jquery": "^3.6.0",
    "typescript": "^4.9.5",
    "typescript-eslint": "^7.6.0"
  },
  "optionalDependencies": {
    "fsevents": "^2.3.2"
  },
  "overrides": {
    "chokidar": "$chokidar",
    "core-js": "$core-js",
    "debug": "$debug",
    "glob-parent": "$glob-parent",
    "nth-check": "$nth-check",
    "postcss": "$postcss",
    "svgo": "$svgo",
    "uuid": "$uuid"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
