{
  "name": "open-sankey",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git@gitlab.com:greel/su-model.git"
  },
  "author": "Alapetite Julien",
  "version": "0.1.9",
  "description": "Open Sankey",
  "license": "MIT",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "dist": "cross-env NODE_ENV=production babel src/lib --extensions .ts,.tsx,.js --out-dir dist",
    "dist_dev": "babel src/lib --out-dir dist --copy-files --ignore __tests__,spec.js,test.js,__snapshots__",
    "test": "react-scripts test --env=jsdom  -t 'AFMBase'",
    "test_regenerate": "react-scripts test -u",
    "jest-html": "jest-html -c **/main.css,**/bootstrap.css",
    "eject": "react-scripts eject",
    "lint": "eslint --fix --ext .js,.jsx,.tsx .",
    "publish": "npm run retrieve_index_html && npm run publish_build && npm run copy_data && npm run restore_index_html && npm run publish2",
    "publish_build": "react-scripts build && shx sed -i \"s/\\/static/static/g\" build/index.html",
    "restore_index_html": "cpr public/index_keep.html public/index.html -o && shx rm -f public/index_keep.html && shx rm -f build/index_keep.html",
    "retrieve_index_html": "cpr public/index.html public/index_keep.html -o && cross-conf-env cpr $npm_config_datapath/index.html public/index.html -o",
    "copy_excel": "cross-conf-env shx --silent cp $npm_config_datapath/*simple.xlsx build || shx true",
    "copy_layout": "cross-conf-env shx cp $npm_config_datapath/sankey/*layout.json build",
    "copy_logo": "cross-conf-env shx cp $npm_config_datapath/*.png  build || shx true",
    "copy_data": "npm run copy_logo && npm run copy_excel && npm run copy_layout",
    "build_zip": "cross-conf-env shx rm -rf $npm_config_datapath/artefacts/opensankey_1.0.0.$npm_config_publish_name.zip && shx rm -f build/index_keep.html && cross-conf-env npm-build-zip --name=$npm_config_publish_name --destination  $npm_config_datapath/artefacts",
    "unzip": "cross-conf-env extract-zip $npm_config_datapath/artefacts/opensankey_1.0.0.$npm_config_publish_name.zip $npm_config_datapath/artefacts/opensankey_1.0.0.$npm_config_publish_name",
    "echo": "cross-conf-env echo $npm_config_datapath",
    "publish2": "node publish.js",
    "remove_header": "node remove_header_footer.js"
  },
  "jest": {
    "snapshotSerializers": [
      "jest-html"
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "proxy": "http://127.0.0.1:5000/",
  "dependencies": {
    "@babel/cli": "^7.13.16",
    "@babel/preset-typescript": "^7.16.7",
    "@popperjs/core": "^2.9.2",
    "@testing-library/jest-dom": "^5.16.1",
    "@testing-library/react": "^12.1.2",
    "@types/d3": "^7.0.0",
    "@types/jest": "^27.4.0",
    "@types/react-dom": "^17.0.9",
    "@types/react-test-renderer": "^17.0.1",
    "acorn": "^8.2.2",
    "bootstrap": "^5.1.1",
    "colormap": "^2.3.2",
    "cpr": "^3.0.1",
    "cross-conf-env": "^1.2.1",
    "cross-env": "^7.0.3",
    "d3": "^6.7.0",
    "d3-textwrap": "^3.0.0",
    "file-saver": "^2.0.5",
    "html-react-parser": "^1.2.7",
    "react": "^17.0.2",
    "react-bootstrap": "^2.0.0-rc.0",
    "react-color": "^2.19.3",
    "react-dom": "^17.0.2",
    "react-icons": "^4.3.1",
    "react-multiselect-dropdown-bootstrap": "^1.1.0",
    "react-scripts": "^5.0.0",
    "react-test-renderer": "^17.0.2",
    "shx": "^0.3.4",
    "ts-jest": "^27.1.2",
    "ts-node": "^10.4.0",
    "typescript": "^4.3.5",
    "yoga-layout-prebuilt": "^1.10.0"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.3",
    "eslint": "^8.6.0",
    "eslint-plugin-mocha": "^8.1.0",
    "eslint-plugin-react": "^7.23.2",
    "jest": "^27.4.5",
    "jest-html": "^1.5.0",
    "jquery": "^3.6.0",
    "popper.js": "^1.16.1"
  },
  "optionalDependencies": {
    "fsevents": "^2.3.2"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
