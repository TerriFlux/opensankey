{
  "name": "open-sankey",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git@gitlab.com:greel/su-model.git"
  },
  "author": "Alapetite Julien",
  "version": "0.12.0dev",
  "description": "Open Sankey",
  "license": "MIT",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "dist": "tsc -p .",
    "test": "react-scripts test --env=jsdom  -t 'AFMBase'",
    "test_regenerate": "react-scripts test -u",
    "jest-html": "jest-html -c **/main.css,**/bootstrap.css",
    "eject": "react-scripts eject",
    "lint": "eslint --fix ./src",
    "build_zip": "cross-conf-env shx rm -rf $npm_config_datapath/artefacts/open-sankey_$npm_package_version.$npm_config_publish_name.zip && cross-conf-env npm-build-zip --name=$npm_config_publish_name --destination  $npm_config_datapath/artefacts"
  },
  "jest": {
    "snapshotSerializers": [
      "jest-html"
    ]
  },
  "proxy": "http://127.0.0.1:5000/",
  "dependencies": {
    "@chakra-ui/anatomy": "^2.2.2",
    "@chakra-ui/react": "^2.8.2",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@fortawesome/fontawesome-svg-core": "^6.5.1",
    "@fortawesome/free-solid-svg-icons": "^6.5.2",
    "@fortawesome/react-fontawesome": "^0.2.0",
    "@jridgewell/sourcemap-codec": "^1.4.15",
    "@testing-library/jest-dom": "^6.4.2",
    "@types/d3": "^7.4.3",
    "@types/jest": "^29.5.12",
    "@types/react-test-renderer": "^18.0.7",
    "bootstrap": "^5.3.2",
    "chokidar": "^3.6.0",
    "colormap": "^2.3.2",
    "core-js": "^3.36.1",
    "cross-conf-env": "^1.3.0",
    "css-select": "^5.1.0",
    "d3": "^7.9.0",
    "d3-textwrap": "^3.0.0",
    "deep-diff": "^1.0.2",
    "file-saver": "^2.0.5",
    "framer-motion": "^11.0.28",
    "glob-parent": "^6.0.2",
    "globals": "^15.0.0",
    "html-react-parser": "^5.1.10",
    "i18next": "^23.11.1",
    "i18next-browser-languagedetector": "^7.2.0",
    "lz-string": "^1.5.0",
    "npm-build-zip": "^1.0.4",
    "nth-check": "^2.1.1",
    "postcss": "^8.4.38",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-beforeunload": "^2.6.0",
    "react-bootstrap": "^2.10.2",
    "react-dom": "^18.2.0",
    "react-draggable": "^4.4.6",
