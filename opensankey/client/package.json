{
  "name": "open-sankey",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "homepage": "https://terriflux.github.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/TerriFlux/opensankey.git"
  },
  "bugs": {
    "url": "https://gitlab.com/su-model/opensankey/-/issues"
  },
  "author": "TerriFlux",
  "version": "1.1.4",
  "description": "Open Sankey",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "dist": "tsc -p .",
    "test": "react-scripts test --env=jsdom  -t 'AFMBase'",
    "test_regenerate": "react-scripts test -u",
    "jest-html": "jest-html -c **/main.css,**/bootstrap.css",
    "eject": "react-scripts eject",
    "lint": "eslint --fix ./src",
    "build_zip": "cross-conf-env shx rm -rf $npm_config_datapath/artifacts/open-sankey_$npm_package_version.$npm_config_publish_name.zip && cross-conf-env npm-build-zip --name=$npm_config_publish_name --destination  $npm_config_datapath/artifacts"
  },
  "jest": {
    "snapshotSerializers": [
      "jest-html"
    ]
  },
  "proxy": "http://127.0.0.1:5000/",
  "dependencies": {
