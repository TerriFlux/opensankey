{
  "name": "open-sankey",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git@gitlab.com:greel/su-model.git"
  },
  "author": "Alapetite Julien",
  "version": "0.9.6",
  "description": "Open Sankey",
  "license": "MIT",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "dist": "tsc -p .",
    "test": "react-scripts test --env=jsdom  -t 'AFMBase'",
    "test_regenerate": "react-scripts test -u",
    "jest-html": "jest-html -c **/main.css,**/bootstrap.css",
    "eject": "react-scripts eject",
    "lint": "eslint --fix --ext .js,.jsx,.tsx .",
    "build_zip": "cross-conf-env shx rm -rf $npm_config_datapath/artefacts/open-sankey_$npm_package_version.$npm_config_publish_name.zip && shx rm -f build/index_keep.html && cross-conf-env npm-build-zip --name=$npm_config_publish_name --destination  $npm_config_datapath/artefacts"
  },
  "jest": {
    "snapshotSerializers": [
      "jest-html"
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "proxy": "http://127.0.0.1:5000/",
  "dependencies": {
    "@babel/cli": "^7.13.16",
    "@babel/preset-typescript": "^7.16.7",
    "@fortawesome/fontawesome-svg-core": "^6.1.1",
