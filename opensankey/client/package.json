  "devDependencies": {
    "@types/file-saver": "^2.0.3",
    "@types/react-dom": "^17.0.13",
    "eslint": "^8.6.0",
    "eslint-plugin-mocha": "^8.1.0",
    "eslint-plugin-react": "^7.23.2",
    "jest": "^27.4.5",
    "jest-html": "^1.5.0",
    "jquery": "^3.6.0",
    "popper.js": "^1.16.1"
